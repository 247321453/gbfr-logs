      {
        "title": "Logs",
        "label": "logs",
        "url": "/logs",
        "fullscreen": false,
        "width": 800,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "closable": true,
        "decorations": true,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --disable-gpu",
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null
    }
